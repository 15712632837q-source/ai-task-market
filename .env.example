# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Admin（你的 Supabase 用户 UUID，注册后在 Supabase → Auth → Users 里查看）
NEXT_PUBLIC_ADMIN_ID=your-admin-user-uuid

# 充值收款账号（显示在充值页面）
NEXT_PUBLIC_RECHARGE_WECHAT=your-wechat-id
NEXT_PUBLIC_RECHARGE_ALIPAY=your-alipay-id
